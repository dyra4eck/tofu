#cloud-config
hostname: ${vm_name}
manage_etc_hosts: true
users:
  - name: admin
    groups: sudo
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: false
    passwd: ${password_hash}
    ssh_authorized_keys:
      - ${ssh_key}

packages:
  - qemu-guest-agent

runcmd:
  - systemctl enable --now qemu-guest-agent
